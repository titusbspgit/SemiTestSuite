      ],
      "path": "TestRepo/pcie/pcie_cfg_wr_rd_test",
      "framework": "C/baremetal",
      "steps": [
        "Read each configuration register with non-zero read mask and compare to default value.",
        "Iterate over data patterns and write to registers with non-zero write mask.",
        "Read back registers with non-zero read mask after each write.",
        "Compute expected using masks and compare with read value.",
        "Accumulate reset and write/read mismatch counters.",
        "Finish with pass if both counters are zero; otherwise fail."
      ],
      "expected_results": [
        "def_fail_cnt == 0 and wr_fail_cnt == 0",
        "On mismatch, logs include CFG_RST_FAIL or CFG_WR_FAIL with address"
      ],
      "parameters": {
        "addresses": ["0x1000", "0x1004", "0x1008", "0x1010", "0x103C"],
        "patterns": ["0xAAAAAAAA", "0x55555555", "0xFFFFFFFF", "0x00000000"],
        "read_masks": ["0xFFFFFFFF", "0xFFFFFFFF", "0xFFFFFFFF", "0xFFFFFFFF", "0x000000FF"],
        "write_masks": ["0x0", "0xFFFFFFFF", "0xFFFFFFFF", "0xFFFFFFF0", "0x0"]
      },
      "tags": ["PCIE"],
      "priority": "P3",
      "type": "functional",
