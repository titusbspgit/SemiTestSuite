      "name": "pcie_cfg_wr_rd_test",
      "description": "Validate PCIe configuration space registers for reset defaults and masked write/read behavior across multiple patterns.",
      "folder_url": "https://github.com/titusbspgit/SemiTestSuite/tree/main/TestRepo/pcie/pcie_cfg_wr_rd_test",
      "files": [
